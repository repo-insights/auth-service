# App
APP_NAME=repoinsight-auth
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-very-long-random-secret-key-in-production

# JWT
JWT_SECRET_KEY=change-me-jwt-secret-key-minimum-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_HOURS=12
JWT_ISSUER=repoinsight-auth
JWT_AUDIENCE=repoinsight-api

# S2S
S2S_SECRET_KEY=change-me-s2s-secret-key
S2S_TOKEN_EXPIRE_MINUTES=10

# Turso
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token
TURSO_DATABASE_TLS=true
DB_BACKEND=libsql
D1_BINDING_NAME=DB
# Optional custom CA bundle for local certificate issues
# TURSO_SSL_CERT_FILE=/absolute/path/to/ca.pem

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Email (SMTP)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-sendgrid-api-key
EMAIL_FROM=noreply@repoinsight.io
EMAIL_FROM_NAME=RepoInsight

# Frontend
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_SIGNUP=3/minute
